---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/ui/HeroSection.astro';
import LatestArticles from '../components/ui/LatestArticles.astro';
import ArticleCard from '../components/ui/ArticleCard.astro';
import ParallaxBand from '../components/ui/ParallaxBand.astro';
import { getCollection } from 'astro:content';

const kitaplar = (await getCollection('spor-kitapligi', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const filmler = (await getCollection('spor-filmografisi', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const cumhuriyet = (await getCollection('cumhuriyet-donemi-spor', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const bloglar = (await getCollection('kisisel-blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);
---

<BaseLayout title="Tozlu Skor — Sporun Toplumsal Hafızası">
  <HeroSection />

  <div class="max-w-6xl mx-auto px-6">
    <div class="fade-in-section">
      <LatestArticles subtitle="Sporu farklı açılardan ele alan kitapların incelemeleri ve okumaları." title="Spor Kitaplığı" href="/spor-kitapligi">
        {kitaplar.map((entry) => (
          <ArticleCard
            title={entry.data.title}
            description={entry.data.description}
            publishDate={entry.data.publishDate}
            slug={entry.id}
            category="spor-kitapligi"
            meta={`${entry.data.bookTitle} — ${entry.data.bookAuthor}`}
            coverImage={entry.data.coverImage}
          />
        ))}
      </LatestArticles>
    </div>
  </div>

  <ParallaxBand quote="Spor, ulusların karakterini en iyi yansıtan aynadır." />

  <div class="max-w-6xl mx-auto px-6">
    <div class="fade-in-section">
      <LatestArticles subtitle="Sporun beyazperdedeki yansımaları: filmler, yönetmenler ve sahneler." title="Spor Filmografisi" href="/spor-filmografisi">
        {filmler.map((entry) => (
          <ArticleCard
            title={entry.data.title}
            description={entry.data.description}
            publishDate={entry.data.publishDate}
            slug={entry.id}
            category="spor-filmografisi"
            meta={`${entry.data.filmTitle} (${entry.data.filmYear}) — ${entry.data.director}`}
            coverImage={entry.data.coverImage}
          />
        ))}
      </LatestArticles>
    </div>
  </div>

  <ParallaxBand />

  <div class="max-w-6xl mx-auto px-6">
    <div class="fade-in-section">
      <LatestArticles subtitle="Cumhuriyet'in kuruluşundan bugüne sporun toplumsal ve siyasal tarihi." title="Cumhuriyet Dönemi Spor" href="/cumhuriyet-donemi-spor">
        {cumhuriyet.map((entry) => (
          <ArticleCard
            title={entry.data.title}
            description={entry.data.description}
            publishDate={entry.data.publishDate}
            slug={entry.id}
            category="cumhuriyet-donemi-spor"
            meta={entry.data.period}
            coverImage={entry.data.coverImage}
          />
        ))}
      </LatestArticles>
    </div>
  </div>

  <ParallaxBand
    quote="Sağlam kafa sağlam vücutta bulunur."
    author="Mustafa Kemal Atatürk"
  />

  <div class="max-w-6xl mx-auto px-6">
    <div class="fade-in-section">
      <LatestArticles subtitle="Spor, toplum ve kültür üzerine kişisel gözlemler ve notlar." title="Yazıyor Yazıyor" href="/kisisel-blog">
        {bloglar.map((entry) => (
          <ArticleCard
            title={entry.data.title}
            description={entry.data.description}
            publishDate={entry.data.publishDate}
            slug={entry.id}
            category="kisisel-blog"
            coverImage={entry.data.coverImage}
          />
        ))}
      </LatestArticles>
    </div>
  </div>
</BaseLayout>

<script>
  // Sadece görünüme girince yumuşak fade-in (parallax jitter kaldırıldı)
  function initFadeIn() {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );

    document.querySelectorAll('.fade-in-section').forEach((el) => {
      observer.observe(el);
    });
  }

  initFadeIn();
</script>
