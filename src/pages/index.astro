---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/ui/HeroSection.astro';
import LatestArticles from '../components/ui/LatestArticles.astro';
import ArticleGrid from '../components/ui/ArticleGrid.astro';
import ParallaxBand from '../components/ui/ParallaxBand.astro';
import { getCollection } from 'astro:content';


const makeExcerpt = (body: string, len = 240) =>
  (body || '')
    .replace(/^---[\s\S]*?---/, '')
    .replace(/[#>*_`~\[\]()]/g, '')
    .replace(/!\?\[[^\]]*\]\([^)]*\)/g, '')
    .replace(/\s+/g, ' ')
    .trim()
    .slice(0, len);

const readMinutes = (body: string) => Math.max(1, Math.round((body || '').split(/\s+/).length / 200));

const sortRecent = (arr: any[]) =>
  arr.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()).slice(0, 4);

const kitaplar = sortRecent(await getCollection('spor-kitapligi', ({ data }) => !data.draft));
const filmler = sortRecent(await getCollection('spor-filmografisi', ({ data }) => !data.draft));
const cumhuriyet = sortRecent(await getCollection('cumhuriyet-donemi-spor', ({ data }) => !data.draft));
const bloglar = sortRecent(await getCollection('kisisel-blog', ({ data }) => !data.draft));

const kitapItems = kitaplar.map((e) => ({
  title: e.data.title, description: e.data.description, publishDate: e.data.publishDate,
  slug: e.id, category: 'spor-kitapligi' as const, excerpt: makeExcerpt(e.body), minutes: readMinutes(e.body),
  meta: `${e.data.bookTitle} — ${e.data.bookAuthor}`, coverImage: e.data.coverImage,
}));
const filmItems = filmler.map((e) => ({
  title: e.data.title, description: e.data.description, publishDate: e.data.publishDate,
  slug: e.id, category: 'spor-filmografisi' as const, excerpt: makeExcerpt(e.body), minutes: readMinutes(e.body),
  meta: `${e.data.filmTitle} (${e.data.filmYear}) — ${e.data.director}`, coverImage: e.data.coverImage,
}));
const cumhuriyetItems = cumhuriyet.map((e) => ({
  title: e.data.title, description: e.data.description, publishDate: e.data.publishDate,
  slug: e.id, category: 'cumhuriyet-donemi-spor' as const, excerpt: makeExcerpt(e.body), minutes: readMinutes(e.body),
  meta: e.data.period, coverImage: e.data.coverImage,
}));
const blogItems = bloglar.map((e) => ({
  title: e.data.title, description: e.data.description, publishDate: e.data.publishDate,
  slug: e.id, category: 'kisisel-blog' as const, excerpt: makeExcerpt(e.body), minutes: readMinutes(e.body), coverImage: e.data.coverImage,
}));
---

<BaseLayout title="Tozlu Skor — Tozlu Skorların Peşinde">
  <HeroSection />

  <div class="max-w-6xl mx-auto px-6">

    <div class="fade-in-section">
      <LatestArticles subtitle="Sporu farklı açılardan ele alan kitapların incelemeleri ve okumaları." title="Spor Kitaplığı" href="/spor-kitapligi">
        <ArticleGrid items={kitapItems} />
      </LatestArticles>
    </div>

    <ParallaxBand quote="Spor, ulusların karakterini en iyi yansıtan aynadır." />

    <div class="fade-in-section">
      <LatestArticles subtitle="Sporun beyazperdedeki yansımaları: filmler, yönetmenler ve sahneler." title="Spor Filmografisi" href="/spor-filmografisi">
        <ArticleGrid items={filmItems} />
      </LatestArticles>
    </div>

    <ParallaxBand />

    <div class="fade-in-section">
      <LatestArticles subtitle="Cumhuriyet'in kuruluşundan bugüne sporun toplumsal ve siyasal tarihi." title="Cumhuriyet Dönemi Spor" href="/cumhuriyet-donemi-spor">
        <ArticleGrid items={cumhuriyetItems} />
      </LatestArticles>
    </div>

    <ParallaxBand quote="Sağlam kafa sağlam vücutta bulunur." author="Mustafa Kemal Atatürk" />

    <div class="fade-in-section">
      <LatestArticles subtitle="Spor, toplum ve kültür üzerine kişisel gözlemler ve notlar." title="Yazıyor Yazıyor" href="/kisisel-blog">
        <ArticleGrid items={blogItems} />
      </LatestArticles>
    </div>

  </div>
</BaseLayout>

<script>
  function initFadeIn() {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) { e.target.classList.add('is-visible'); observer.unobserve(e.target); }
        });
      },
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.fade-in-section').forEach((el) => observer.observe(el));
  }
  initFadeIn();
</script>
