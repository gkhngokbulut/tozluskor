---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/ui/HeroSection.astro';
import LatestArticles from '../components/ui/LatestArticles.astro';
import ArticleCard from '../components/ui/ArticleCard.astro';
import ParallaxBand from '../components/ui/ParallaxBand.astro';
import { getCollection } from 'astro:content';

const kitaplar = (await getCollection('spor-kitapligi', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const filmler = (await getCollection('spor-filmografisi', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const cumhuriyet = (await getCollection('cumhuriyet-donemi-spor', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const bloglar = (await getCollection('kisisel-blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);
---

<BaseLayout title="Tozlu Skor — Sporun Toplumsal Hafızası">
  <HeroSection />

  <div class="content-section relative z-10" data-depth="0.03">
    <div class="max-w-6xl mx-auto px-4">
      <div class="fade-in-section">
        <LatestArticles title="Spor Kitaplığı" href="/spor-kitapligi">
          {kitaplar.map((entry) => (
            <ArticleCard
              title={entry.data.title}
              description={entry.data.description}
              publishDate={entry.data.publishDate}
              slug={entry.id}
              category="spor-kitapligi"
              meta={`${entry.data.bookTitle} — ${entry.data.bookAuthor}`}
            />
          ))}
        </LatestArticles>
      </div>
    </div>
  </div>

  <ParallaxBand
    quote="Spor, ulusların karakterini en iyi yansıtan aynadır."
  />

  <div class="content-section relative z-10" data-depth="0.04">
    <div class="max-w-6xl mx-auto px-4">
      <div class="fade-in-section">
        <LatestArticles title="Spor Filmografisi" href="/spor-filmografisi">
          {filmler.map((entry) => (
            <ArticleCard
              title={entry.data.title}
              description={entry.data.description}
              publishDate={entry.data.publishDate}
              slug={entry.id}
              category="spor-filmografisi"
              meta={`${entry.data.filmTitle} (${entry.data.filmYear}) — ${entry.data.director}`}
            />
          ))}
        </LatestArticles>
      </div>
    </div>
  </div>

  <ParallaxBand />

  <div class="content-section relative z-10" data-depth="0.03">
    <div class="max-w-6xl mx-auto px-4">
      <div class="fade-in-section">
        <LatestArticles title="Cumhuriyet Dönemi Spor" href="/cumhuriyet-donemi-spor">
          {cumhuriyet.map((entry) => (
            <ArticleCard
              title={entry.data.title}
              description={entry.data.description}
              publishDate={entry.data.publishDate}
              slug={entry.id}
              category="cumhuriyet-donemi-spor"
              meta={entry.data.period}
            />
          ))}
        </LatestArticles>
      </div>
    </div>
  </div>

  <ParallaxBand
    quote="Sağlam kafa sağlam vücutta bulunur."
    author="Mustafa Kemal Atatürk"
  />

  <div class="content-section relative z-10" data-depth="0.04">
    <div class="max-w-6xl mx-auto px-4">
      <div class="fade-in-section">
        <LatestArticles title="Yazıyor Yazıyor" href="/kisisel-blog">
          {bloglar.map((entry) => (
            <ArticleCard
              title={entry.data.title}
              description={entry.data.description}
              publishDate={entry.data.publishDate}
              slug={entry.id}
              category="kisisel-blog"
            />
          ))}
        </LatestArticles>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  // Parallax scroll handler — different layers move at different speeds
  function initParallax() {
    const layers = document.querySelectorAll<HTMLElement>('.parallax-layer');
    const sections = document.querySelectorAll<HTMLElement>('.content-section');
    let ticking = false;

    function updateParallax() {
      const scrollY = window.scrollY;

      // Parallax layers inside hero & bands
      layers.forEach((layer) => {
        const speed = parseFloat(layer.dataset.speed || '0.2');
        const parent = layer.closest('section, .parallax-band') as HTMLElement;
        if (!parent) return;
        const rect = parent.getBoundingClientRect();
        const parentTop = rect.top + scrollY;
        const offset = (scrollY - parentTop) * speed;
        layer.style.transform = `translate3d(0, ${offset}px, 0)`;
      });

      // Subtle depth shift on content sections
      sections.forEach((section) => {
        const depth = parseFloat(section.dataset.depth || '0.03');
        const rect = section.getBoundingClientRect();
        const center = rect.top + rect.height / 2;
        const viewCenter = window.innerHeight / 2;
        const diff = (center - viewCenter) * depth;
        section.style.transform = `translate3d(0, ${diff}px, 0)`;
      });

      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(updateParallax);
        ticking = true;
      }
    }, { passive: true });

    updateParallax();
  }

  // Intersection Observer for fade-in animations
  function initFadeIn() {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );

    document.querySelectorAll('.fade-in-section').forEach((el) => {
      observer.observe(el);
    });
  }

  // Disable parallax on mobile for performance
  if (window.innerWidth > 768) {
    initParallax();
  }
  initFadeIn();
</script>
