---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/ui/HeroSection.astro';
import LatestArticles from '../components/ui/LatestArticles.astro';
import ArticleCard from '../components/ui/ArticleCard.astro';
import ParallaxBand from '../components/ui/ParallaxBand.astro';
import { getCollection } from 'astro:content';

const kitaplar = (await getCollection('spor-kitapligi', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()).slice(0, 4);
const filmler = (await getCollection('spor-filmografisi', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()).slice(0, 4);
const cumhuriyet = (await getCollection('cumhuriyet-donemi-spor', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()).slice(0, 4);
const bloglar = (await getCollection('kisisel-blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()).slice(0, 4);
---

<BaseLayout title="Tozlu Skor — Tozlu Skorların Peşinde">
  <HeroSection />

  <div class="max-w-6xl mx-auto px-6">

    <!-- Spor Kitaplığı -->
    <div class="fade-in-section">
      <LatestArticles subtitle="Sporu farklı açılardan ele alan kitapların incelemeleri ve okumaları." title="Spor Kitaplığı" href="/spor-kitapligi">
        {kitaplar.length > 0 && (
          <div class="featured-layout col-span-full">
            {kitaplar.slice(0, 1).map((entry) => (
              <ArticleCard title={entry.data.title} description={entry.data.description}
                publishDate={entry.data.publishDate} slug={entry.id}
                category="spor-kitapligi" meta={`${entry.data.bookTitle} — ${entry.data.bookAuthor}`}
                coverImage={entry.data.coverImage} featured />
            ))}
            <div class="side-cards">
              {kitaplar.slice(1).map((entry) => (
                <ArticleCard title={entry.data.title} description={entry.data.description}
                  publishDate={entry.data.publishDate} slug={entry.id}
                  category="spor-kitapligi" meta={`${entry.data.bookTitle} — ${entry.data.bookAuthor}`}
                  coverImage={entry.data.coverImage} />
              ))}
            </div>
          </div>
        )}
      </LatestArticles>
    </div>

    <ParallaxBand quote="Spor, ulusların karakterini en iyi yansıtan aynadır." />

    <!-- Spor Filmografisi -->
    <div class="fade-in-section">
      <LatestArticles subtitle="Sporun beyazperdedeki yansımaları: filmler, yönetmenler ve sahneler." title="Spor Filmografisi" href="/spor-filmografisi">
        {filmler.length > 0 && (
          <div class="featured-layout col-span-full">
            {filmler.slice(0, 1).map((entry) => (
              <ArticleCard title={entry.data.title} description={entry.data.description}
                publishDate={entry.data.publishDate} slug={entry.id}
                category="spor-filmografisi" meta={`${entry.data.filmTitle} (${entry.data.filmYear}) — ${entry.data.director}`}
                coverImage={entry.data.coverImage} featured />
            ))}
            <div class="side-cards">
              {filmler.slice(1).map((entry) => (
                <ArticleCard title={entry.data.title} description={entry.data.description}
                  publishDate={entry.data.publishDate} slug={entry.id}
                  category="spor-filmografisi" meta={`${entry.data.filmTitle} (${entry.data.filmYear}) — ${entry.data.director}`}
                  coverImage={entry.data.coverImage} />
              ))}
            </div>
          </div>
        )}
      </LatestArticles>
    </div>

    <ParallaxBand />

    <!-- Cumhuriyet Dönemi Spor -->
    <div class="fade-in-section">
      <LatestArticles subtitle="Cumhuriyet'in kuruluşundan bugüne sporun toplumsal ve siyasal tarihi." title="Cumhuriyet Dönemi Spor" href="/cumhuriyet-donemi-spor">
        {cumhuriyet.length > 0 && (
          <div class="featured-layout col-span-full">
            {cumhuriyet.slice(0, 1).map((entry) => (
              <ArticleCard title={entry.data.title} description={entry.data.description}
                publishDate={entry.data.publishDate} slug={entry.id}
                category="cumhuriyet-donemi-spor" meta={entry.data.period}
                coverImage={entry.data.coverImage} featured />
            ))}
            <div class="side-cards">
              {cumhuriyet.slice(1).map((entry) => (
                <ArticleCard title={entry.data.title} description={entry.data.description}
                  publishDate={entry.data.publishDate} slug={entry.id}
                  category="cumhuriyet-donemi-spor" meta={entry.data.period}
                  coverImage={entry.data.coverImage} />
              ))}
            </div>
          </div>
        )}
      </LatestArticles>
    </div>

    <ParallaxBand quote="Sağlam kafa sağlam vücutta bulunur." author="Mustafa Kemal Atatürk" />

    <!-- Yazıyor Yazıyor -->
    <div class="fade-in-section">
      <LatestArticles subtitle="Spor, toplum ve kültür üzerine kişisel gözlemler ve notlar." title="Yazıyor Yazıyor" href="/kisisel-blog">
        {bloglar.length > 0 && (
          <div class="featured-layout col-span-full">
            {bloglar.slice(0, 1).map((entry) => (
              <ArticleCard title={entry.data.title} description={entry.data.description}
                publishDate={entry.data.publishDate} slug={entry.id}
                category="kisisel-blog" coverImage={entry.data.coverImage} featured />
            ))}
            <div class="side-cards">
              {bloglar.slice(1).map((entry) => (
                <ArticleCard title={entry.data.title} description={entry.data.description}
                  publishDate={entry.data.publishDate} slug={entry.id}
                  category="kisisel-blog" coverImage={entry.data.coverImage} />
              ))}
            </div>
          </div>
        )}
      </LatestArticles>
    </div>

  </div>
</BaseLayout>

<style>
  /* Featured + yan kartlar yan yana layout */
  .featured-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 768px) {
    .featured-layout {
      grid-template-columns: 3fr 2fr;
      align-items: start;
    }
  }
  .side-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
</style>

<script>
  function initFadeIn() {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) { e.target.classList.add('is-visible'); observer.unobserve(e.target); }
        });
      },
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.fade-in-section').forEach((el) => observer.observe(el));
  }
  initFadeIn();
</script>
