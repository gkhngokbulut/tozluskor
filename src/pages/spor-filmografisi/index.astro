---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ui/ArticleCard.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import Pagination from '../../components/ui/Pagination.astro';
import { getCollection } from 'astro:content';

const PER_PAGE = 8;
const readMinutes = (body) => Math.max(1, Math.round((body || '').split(/\s+/).length / 200));
const makeExcerpt = (body) =>
  (body || '').replace(/^---[\s\S]*?---/, '').replace(/[#>*_`~\[\]()]/g, '').replace(/\s+/g, ' ').trim().slice(0, 240);

const allEntries = (await getCollection('spor-filmografisi', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const totalPages = Math.max(1, Math.ceil(allEntries.length / PER_PAGE));
const entries = allEntries.slice(0, PER_PAGE);
---

<BaseLayout title="Spor Filmografisi — Tozlu Skor" description="Spor filmlerinin incelemeleri ve analizleri.">

  <div class="bg-vintage-dark text-vintage-cream">
    <div class="max-w-6xl mx-auto px-6 py-12 md:py-16">
      <Breadcrumb items={[{ label: 'Spor Filmografisi' }]} tone="dark" />
      <p class="text-[10px] tracking-[0.35em] uppercase text-vintage-gold/55 mb-4 mt-4">Arşiv</p>
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-vintage-cream leading-tight mb-4">
        Spor Filmografisi
      </h1>
      <div class="flex items-center gap-3 mb-5">
        <div class="w-8 h-px bg-vintage-gold/40"></div>
        <div class="w-1 h-1 bg-vintage-gold/50 rotate-45 shrink-0"></div>
        <div class="w-16 h-px bg-vintage-gold/20"></div>
      </div>
      <p class="text-vintage-cream/50 text-base max-w-2xl font-body leading-relaxed">
        Beyazperdeden Sahaya: Görsel Kültürde Sporun Temsili; Film, Dizi ve Belgesel Çözümlemeleri
      </p>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-6 py-12">
    {entries.length === 0 ? (
      <p class="text-vintage-muted text-center py-16">Henüz içerik eklenmemiş.</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
        {entries.map((entry) => (
          <ArticleCard
            title={entry.data.title}
            description={entry.data.description}
            publishDate={entry.data.publishDate}
            slug={entry.id}
            category="spor-filmografisi"
            meta={`${entry.data.filmTitle} (${entry.data.filmYear}) — ${entry.data.director}`}
            coverImage={entry.data.coverImage}
            excerpt={makeExcerpt(entry.body)}
            minutes={readMinutes(entry.body)}
          />
        ))}
      </div>
    )}
    <Pagination currentPage={1} totalPages={totalPages} baseUrl="/spor-filmografisi" />
  </div>
</BaseLayout>
