---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ui/ArticleCard.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import Pagination from '../../../components/ui/Pagination.astro';
import { getCollection } from 'astro:content';

const PER_PAGE = 8;

const readMinutes = (body) =>
  Math.max(1, Math.round((body || '').split(/\s+/).length / 200));

const makeExcerpt = (body) =>
  (body || '')
    .replace(/^---[\s\S]*?---/, '')
    .replace(/[#>*_`~\[\]()]/g, '')
    .replace(/\s+/g, ' ')
    .trim()
    .slice(0, 240);

export async function getStaticPaths() {
  const PER_PAGE = 8;
  const all = (await getCollection('kisisel-blog', ({ data }) => !data.draft))
    .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

  const totalPages = Math.ceil(all.length / PER_PAGE);

  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, i) => ({
    params: { page: String(i + 2) },
    props: {
      entries: all.slice((i + 1) * PER_PAGE, (i + 2) * PER_PAGE),
      currentPage: i + 2,
      totalPages,
    },
  }));
}

const { entries, currentPage, totalPages } = Astro.props;
---

<BaseLayout title={`Yazıyor Yazıyor — Sayfa ${currentPage} — Tozlu Skor`}>
  <div class="bg-vintage-dark text-vintage-cream">
    <div class="max-w-6xl mx-auto px-6 py-12 md:py-16">
      <Breadcrumb
        items={[
          { label: 'Yazıyor Yazıyor', href: '/kisisel-blog' },
          { label: `Sayfa ${currentPage}` },
        ]}
        tone="dark"
      />

      <p class="text-[10px] tracking-[0.35em] uppercase text-vintage-gold/55 mb-4 mt-4">
        Arşiv
      </p>

      <h1 class="font-heading text-4xl md:text-5xl font-bold text-vintage-cream leading-tight mb-4">
        Yazıyor Yazıyor
      </h1>

      <div class="flex items-center gap-3 mb-5">
        <div class="w-8 h-px bg-vintage-gold/40"></div>
        <div class="w-1 h-1 bg-vintage-gold/50 rotate-45 shrink-0"></div>
        <div class="w-16 h-px bg-vintage-gold/20"></div>
      </div>

      <p class="text-vintage-cream/50 text-base max-w-2xl font-body leading-relaxed">
        Skor Tabelasının Ötesi: Spor, Toplum ve Kültür Üzerine Denemeler/Gözlemler.
      </p>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
      {entries.map((entry) => (
        <ArticleCard
          title={entry.data.title}
          description={entry.data.description}
          publishDate={entry.data.publishDate}
          slug={entry.id}
          category="kisisel-blog"
          coverImage={entry.data.coverImage}
          excerpt={makeExcerpt(entry.body)}
          minutes={readMinutes(entry.body)}
        />
      ))}
    </div>

    <Pagination
      currentPage={currentPage}
      totalPages={totalPages}
      baseUrl="/kisisel-blog"
    />
  </div>
</BaseLayout>
