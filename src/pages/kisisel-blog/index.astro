---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ui/ArticleCard.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('kisisel-blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<BaseLayout title="Kişisel Blog — Tozlu Skor" description="Spor ve toplum üzerine kişisel gözlemler ve düşünceler.">
  <div class="max-w-6xl mx-auto px-4 py-10">
    <Breadcrumb items={[{ label: 'Kişisel Blog' }]} />

    <header class="mb-10">
      <h1 class="font-heading text-4xl font-bold text-vintage-dark mb-3">Kişisel Blog</h1>
      <p class="text-vintage-muted text-lg max-w-2xl">
        Spor ve toplum üzerine kişisel gözlemler, düşünceler ve denemeler.
      </p>
    </header>

    {entries.length === 0 ? (
      <p class="text-vintage-muted text-center py-12">Henüz içerik eklenmemiş.</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {entries.map((entry) => (
          <ArticleCard
            title={entry.data.title}
            description={entry.data.description}
            publishDate={entry.data.publishDate}
            slug={entry.id}
            category="kisisel-blog"
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
