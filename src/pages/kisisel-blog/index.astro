---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ui/ArticleCard.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('kisisel-blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<BaseLayout title="Yazıyor Yazıyor — Tozlu Skor" description="Spor ve toplum üzerine kişisel notlar.">

  <div class="bg-vintage-dark text-vintage-cream">
    <div class="max-w-6xl mx-auto px-6 py-12 md:py-16">
      <Breadcrumb items={[{ label: 'Yazıyor Yazıyor' }]} />
      <p class="text-[10px] tracking-[0.35em] uppercase text-vintage-gold/55 mb-4 mt-4">Arşiv</p>
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-vintage-cream leading-tight mb-4">
        Yazıyor Yazıyor
      </h1>
      <div class="flex items-center gap-3 mb-5">
        <div class="w-8 h-px bg-vintage-gold/40"></div>
        <div class="w-1 h-1 bg-vintage-gold/50 rotate-45 shrink-0"></div>
        <div class="w-16 h-px bg-vintage-gold/20"></div>
      </div>
      <p class="text-vintage-cream/50 text-base max-w-xl font-body leading-relaxed">
        Spor, toplum ve kültür üzerine kişisel gözlemler, notlar ve düşünceler.
      </p>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-6 py-12">
    {entries.length === 0 ? (
      <p class="text-vintage-muted text-center py-16">Henüz içerik eklenmemiş.</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {entries.map((entry) => (
          <ArticleCard
            title={entry.data.title}
            description={entry.data.description}
            publishDate={entry.data.publishDate}
            slug={entry.id}
            category="kisisel-blog"
            coverImage={entry.data.coverImage}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
