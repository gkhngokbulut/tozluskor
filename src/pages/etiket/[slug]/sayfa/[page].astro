---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../../components/ui/ArticleCard.astro';
import Breadcrumb from '../../../../components/ui/Breadcrumb.astro';
import Pagination from '../../../../components/ui/Pagination.astro';
import { getCollection } from 'astro:content';

const PER_PAGE = 4;

const readMinutes = (body: string) => Math.max(1, Math.round((body || '').split(/\s+/).length / 200));
const makeExcerpt = (body: string) =>
  (body || '').replace(/^---[\s\S]*?---/, '').replace(/[#>*_`~\[\]()]/g, '').replace(/\s+/g, ' ').trim().slice(0, 240);

const categoryMeta: Record<string, (e: any) => string | undefined> = {
  'spor-kitapligi': (e) => `${e.data.bookTitle} — ${e.data.bookAuthor}`,
  'spor-filmografisi': (e) => `${e.data.filmTitle} (${e.data.filmYear}) — ${e.data.director}`,
  'cumhuriyet-donemi-spor': (e) => e.data.period,
  'kisisel-blog': () => undefined,
};

function toSlug(tag: string): string {
  return tag
    .toLowerCase()
    .replace(/ğ/g,'g').replace(/ü/g,'u').replace(/ş/g,'s')
    .replace(/ı/g,'i').replace(/ö/g,'o').replace(/ç/g,'c')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '');
}

export async function getStaticPaths() {
  function toSlug(tag: string): string {
    return tag
      .toLowerCase()
      .replace(/ğ/g,'g').replace(/ü/g,'u').replace(/ş/g,'s')
      .replace(/ı/g,'i').replace(/ö/g,'o').replace(/ç/g,'c')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-|-$/g, '');
  }

  const collections = ['spor-kitapligi', 'spor-filmografisi', 'cumhuriyet-donemi-spor', 'kisisel-blog'] as const;
  const allEntries: { entry: any; category: string }[] = [];

  for (const col of collections) {
    const entries = await getCollection(col, ({ data }: any) => !data.draft);
    for (const e of entries) allEntries.push({ entry: e, category: col });
  }

  const tagMap = new Map<string, { label: string; items: typeof allEntries }>();
  for (const item of allEntries) {
    for (const tag of (item.entry.data.tags || []) as string[]) {
      const slug = toSlug(tag);
      if (!tagMap.has(slug)) tagMap.set(slug, { label: tag, items: [] });
      tagMap.get(slug)!.items.push(item);
    }
  }

  const paths: any[] = [];
  for (const [tagSlug, { label, items }] of tagMap.entries()) {
    const sorted = items.sort((a, b) => b.entry.data.publishDate.getTime() - a.entry.data.publishDate.getTime());
    const totalPages = Math.ceil(sorted.length / 4);
    for (let i = 2; i <= totalPages; i++) {
      paths.push({
        params: { slug: tagSlug, page: String(i) },
        props: {
          tagLabel: label,
          entries: sorted.slice((i - 1) * 4, i * 4),
          currentPage: i,
          totalPages,
        },
      });
    }
  }
  return paths;
}

const { tagLabel, entries, currentPage, totalPages } = Astro.props;
const { slug } = Astro.params;
---

<BaseLayout title={`${tagLabel} Etiketli Yazılar — Sayfa ${currentPage} — Tozlu Skor`} description={`Tozlu Skor arşivinde ${tagLabel} etiketiyle yayımlanan yazılar, sayfa ${currentPage}.`}>

  <div class="bg-vintage-dark text-vintage-cream">
    <div class="max-w-6xl mx-auto px-6 py-12 md:py-16">
      <Breadcrumb items={[{ label: `#${tagLabel}`, href: `/etiket/${slug}/` }, { label: `Sayfa ${currentPage}` }]} tone="dark" />
      <p class="text-[10px] tracking-[0.35em] uppercase text-vintage-gold/55 mb-4 mt-4">Etiket</p>
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-vintage-cream leading-tight mb-4">
        #{tagLabel}
      </h1>
      <div class="flex items-center gap-3 mb-5">
        <div class="w-10 h-[2px] bg-gradient-to-r from-vintage-gold/60 to-vintage-gold/20 rounded-full"></div>
        <div class="w-1.5 h-1.5 bg-vintage-gold/35 rotate-45 shrink-0"></div>
        <div class="w-20 h-px bg-vintage-gold/10"></div>
      </div>
      <p class="text-vintage-cream/50 text-base max-w-2xl font-body leading-relaxed">
        Bu etiketle ilişkili tüm yazılar.
      </p>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
      {entries.map(({ entry, category }: any) => (
        <ArticleCard
          title={entry.data.title}
          description={entry.data.description}
          publishDate={entry.data.publishDate}
          slug={entry.id}
          category={category}
          meta={categoryMeta[category]?.(entry)}
          coverImage={entry.data.coverImage}
          excerpt={makeExcerpt(entry.body)}
          minutes={readMinutes(entry.body)}
        />
      ))}
    </div>
    <Pagination currentPage={currentPage} totalPages={totalPages} baseUrl={`/etiket/${slug}`} />

    <div class="text-center mt-8">
      <a href="/" class="inline-block text-[11px] text-vintage-brown/50 hover:text-vintage-red transition-colors uppercase tracking-[0.18em]">
        &larr; Arşive Dön
      </a>
    </div>
  </div>
</BaseLayout>
