---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Spor tarihi, kitap analizleri, film incelemeleri ve toplumsal perspektifler.',
  ogImage = '/og-default.jpg',
} = Astro.props;

const siteUrl = 'https://tozluskor.vercel.app';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph / Sosyal medya -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:locale" content="tr_TR" />
    <meta property="og:site_name" content="Tozlu Skor" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@TozluSkor" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Fontlar -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,400;1,700&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script is:inline>
      // Açılış ekranı sadece oturumun ilk yüklemesinde gösterilir
      if (!sessionStorage.getItem('ts_loaded')) {
        document.documentElement.classList.add('is-loading');
      }
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Açılış ekranı -->
    <div class="site-loader" aria-hidden="true">
      <div class="site-loader__inner">
        <img src="/logo.png" alt="Tozlu Skor" class="site-loader__logo" />
        <span class="site-loader__bar"></span>
      </div>
    </div>

    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- Hover içerik önizleme popover'ı (site geneli) -->
    <div id="hover-preview" class="hover-preview" aria-hidden="true">
      <div class="hp-media"><img alt="" /></div>
      <div class="hp-body">
        <span class="hp-cat"></span>
        <h4 class="hp-title"></h4>
        <p class="hp-excerpt"></p>
        <div class="hp-foot">
          <span class="hp-min"></span>
          <span class="hp-cta">Yazıyı Oku &rarr;</span>
        </div>
      </div>
    </div>
    <script is:inline>
      (function () {
        if (!window.matchMedia || !window.matchMedia('(hover: hover)').matches) return;
        const pop = document.getElementById('hover-preview');
        if (!pop) return;
        const media = pop.querySelector('.hp-media');
        const img = pop.querySelector('.hp-media img');
        const cat = pop.querySelector('.hp-cat');
        const title = pop.querySelector('.hp-title');
        const exc = pop.querySelector('.hp-excerpt');
        const min = pop.querySelector('.hp-min');
        let timer, current;

        function fill(card) {
          const d = card.dataset;
          title.textContent = d.pvTitle || '';
          cat.textContent = d.pvCat || '';
          let text = d.pvExcerpt || '';
          exc.textContent = text ? text + '…' : '';
          if (d.pvImg) { img.src = d.pvImg; media.style.display = ''; }
          else { media.style.display = 'none'; }
          min.textContent = d.pvMin ? (d.pvMin + ' dk okuma') : '';
        }

        function place(card) {
          const r = card.getBoundingClientRect();
          const pw = pop.offsetWidth, ph = pop.offsetHeight;
          const gap = 14;
          let left = r.right + gap;
          if (left + pw > window.innerWidth - 12) left = r.left - pw - gap;
          if (left < 12) left = Math.min(r.left, window.innerWidth - pw - 12);
          let top = r.top + (r.height - ph) / 2;
          top = Math.max(12, Math.min(top, window.innerHeight - ph - 12));
          pop.style.left = left + 'px';
          pop.style.top = top + 'px';
        }

        document.querySelectorAll('[data-preview]').forEach((card) => {
          card.addEventListener('mouseenter', () => {
            current = card;
            clearTimeout(timer);
            timer = setTimeout(() => {
              fill(card);
              pop.style.visibility = 'hidden';
              pop.classList.add('show');
              requestAnimationFrame(() => { place(card); pop.style.visibility = ''; });
            }, 90);
          });
          card.addEventListener('mouseleave', () => {
            clearTimeout(timer);
            if (current === card) { pop.classList.remove('show'); current = null; }
          });
        });

        window.addEventListener('scroll', () => { pop.classList.remove('show'); current = null; }, { passive: true });
      })();
    </script>
    <script is:inline>
      (function () {
        const loader = document.querySelector('.site-loader');
        if (!loader) return;
        function dismiss() {
          sessionStorage.setItem('ts_loaded', '1');
          loader.classList.add('site-loader--hide');
          document.documentElement.classList.remove('is-loading');
          setTimeout(() => loader.remove(), 700);
        }
        if (sessionStorage.getItem('ts_loaded')) {
          loader.remove();
          document.documentElement.classList.remove('is-loading');
        } else {
          window.addEventListener('load', () => setTimeout(dismiss, 600));
          // Güvenlik: 3sn sonra zorla kapat
          setTimeout(dismiss, 3000);
        }
      })();
    </script>
    <script is:inline>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", user => {
          if (!user) {
            window.netlifyIdentity.on("login", () => {
              document.location.href = "/admin/";
            });
          }
        });
      }
    </script>
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </body>
</html>
