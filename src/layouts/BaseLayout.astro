---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Spor tarihi, kitap analizleri, film incelemeleri ve toplumsal perspektifler.',
  ogImage = '/og-default.jpg',
} = Astro.props;

const siteUrl = 'https://tozluskor.vercel.app';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph / Sosyal medya -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:locale" content="tr_TR" />
    <meta property="og:site_name" content="Tozlu Skor" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@TozluSkor" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Fontlar -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,400;1,700&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script is:inline>
      // Açılış ekranı sadece oturumun ilk yüklemesinde gösterilir
      if (!sessionStorage.getItem('ts_loaded')) {
        document.documentElement.classList.add('is-loading');
      }
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Açılış ekranı -->
    <div class="site-loader" aria-hidden="true">
      <div class="site-loader__inner">
        <img src="/logo.png" alt="Tozlu Skor" class="site-loader__logo" />
        <span class="site-loader__bar"></span>
      </div>
    </div>

    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- Hızlı Oku penceresi (site geneli) -->
    <div id="quick-read" class="qr-overlay" aria-hidden="true">
      <div class="qr-backdrop"></div>
      <div class="qr-modal" role="dialog" aria-modal="true" aria-label="Hızlı okuma">
        <button class="qr-close" aria-label="Kapat" type="button">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" d="M6 6l12 12M18 6L6 18"/></svg>
        </button>
        <div class="qr-scroll">
          <a class="qr-media" href="#"><img alt="" /></a>
          <div class="qr-head">
            <span class="qr-cat"></span>
            <a class="qr-titlelink" href="#"><h2 class="qr-title"></h2></a>
            <p class="qr-meta"></p>
            <div class="qr-rule"><span class="l"></span><span class="d"></span><span class="l"></span></div>
          </div>
          <div class="qr-content prose prose-lg max-w-none font-body"></div>
          <div class="qr-foot">
            <a class="qr-fullpage" href="#">Tam sayfada aç &rarr;</a>
          </div>
        </div>
      </div>
    </div>
    <script is:inline>
      (function () {
        const overlay = document.getElementById('quick-read');
        if (!overlay) return;
        const hoverable = window.matchMedia && window.matchMedia('(hover: hover)').matches;
        if (!hoverable) return; // dokunmatik cihazlarda link normal çalışır

        const modal = overlay.querySelector('.qr-modal');
        const scroll = overlay.querySelector('.qr-scroll');
        const mediaLink = overlay.querySelector('.qr-media');
        const img = overlay.querySelector('.qr-media img');
        const titleLink = overlay.querySelector('.qr-titlelink');
        const cat = overlay.querySelector('.qr-cat');
        const title = overlay.querySelector('.qr-title');
        const meta = overlay.querySelector('.qr-meta');
        const content = overlay.querySelector('.qr-content');
        const fullpage = overlay.querySelector('.qr-fullpage');
        const closeBtn = overlay.querySelector('.qr-close');
        const cache = {};
        let openTimer, closeTimer, safetyTimer, enteredModal = false, isOpen = false, currentHref = '';

        function load(href) {
          if (cache[href]) { content.innerHTML = cache[href]; return; }
          content.innerHTML = '<p class="qr-loading">İçerik yükleniyor…</p>';
          fetch(href).then((r) => r.text()).then((html) => {
            const doc = new DOMParser().parseFromString(html, 'text/html');
            const prose = doc.querySelector('.prose');
            const out = prose ? prose.innerHTML : '<p>İçerik getirilemedi.</p>';
            cache[href] = out;
            content.innerHTML = out;
          }).catch(() => {
            content.innerHTML = '<p>İçerik yüklenemedi. <a href="' + href + '">Yazıyı sayfasında açın.</a></p>';
          });
        }

        function open(card) {
          const d = card.dataset;
          const href = d.pvHref;
          if (!href) return;
          cat.textContent = d.pvCat || '';
          title.textContent = d.pvTitle || '';
          const bits = [];
          if (d.pvMeta) bits.push(d.pvMeta);
          if (d.pvMin) bits.push(d.pvMin + ' dk okuma');
          meta.textContent = bits.join('  ·  ');
          if (d.pvImg) { img.src = d.pvImg; mediaLink.style.display = ''; }
          else { mediaLink.style.display = 'none'; }
          fullpage.href = href; titleLink.href = href; mediaLink.href = href; currentHref = href;
          load(href);
          overlay.classList.add('show');
          overlay.setAttribute('aria-hidden', 'false');
          document.documentElement.classList.add('qr-open');
          scroll.scrollTop = 0;
          isOpen = true; enteredModal = false;
          clearTimeout(safetyTimer);
          // Modal'e girilmezse güvenlik kapanışı
          safetyTimer = setTimeout(() => { if (!enteredModal) close(); }, 1400);
        }

        function close() {
          clearTimeout(safetyTimer); clearTimeout(closeTimer);
          overlay.classList.remove('show');
          overlay.setAttribute('aria-hidden', 'true');
          document.documentElement.classList.remove('qr-open');
          isOpen = false; enteredModal = false;
        }

        // Kartlar: hover ile aç (gecikmeli), tıklayınca sayfaya git
        document.querySelectorAll('[data-preview]').forEach((card) => {
          card.addEventListener('mouseenter', () => {
            if (isOpen) return;
            clearTimeout(openTimer);
            openTimer = setTimeout(() => open(card), 260);
          });
          card.addEventListener('mouseleave', () => clearTimeout(openTimer));
          // tıklama: açma zamanlayıcısını iptal et, linkin normal çalışmasına izin ver
          card.addEventListener('click', () => clearTimeout(openTimer));
        });

        // Modal'e girince kalıcı, çıkınca gecikmeli kapan
        modal.addEventListener('mouseenter', () => { enteredModal = true; clearTimeout(closeTimer); clearTimeout(safetyTimer); });
        modal.addEventListener('mouseleave', () => { closeTimer = setTimeout(close, 260); });

        modal.addEventListener('click', (e) => {
          if (e.target.closest('.qr-close') || e.target.closest('a')) return;
          if (currentHref) window.location.href = currentHref;
        });
        closeBtn.addEventListener('click', (e) => { e.stopPropagation(); close(); });
        overlay.querySelector('.qr-backdrop').addEventListener('click', close);
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
      })();
    </script>
    <script is:inline>
      (function () {
        const loader = document.querySelector('.site-loader');
        if (!loader) return;
        function dismiss() {
          sessionStorage.setItem('ts_loaded', '1');
          loader.classList.add('site-loader--hide');
          document.documentElement.classList.remove('is-loading');
          setTimeout(() => loader.remove(), 700);
        }
        if (sessionStorage.getItem('ts_loaded')) {
          loader.remove();
          document.documentElement.classList.remove('is-loading');
        } else {
          window.addEventListener('load', () => setTimeout(dismiss, 600));
          // Güvenlik: 3sn sonra zorla kapat
          setTimeout(dismiss, 3000);
        }
      })();
    </script>
    <script is:inline>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", user => {
          if (!user) {
            window.netlifyIdentity.on("login", () => {
              document.location.href = "/admin/";
            });
          }
        });
      }
    </script>
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </body>
</html>
