---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Spor tarihi, kitap analizleri, film incelemeleri ve toplumsal perspektifler.',
  ogImage = '/og-default.jpg',
} = Astro.props;

const siteUrl = 'https://tozluskor.vercel.app';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph / Sosyal medya -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:locale" content="tr_TR" />
    <meta property="og:site_name" content="Tozlu Skor" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@TozluSkor" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Fontlar -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,400;1,700&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script is:inline>
      // Açılış ekranı sadece oturumun ilk yüklemesinde gösterilir
      if (!sessionStorage.getItem('ts_loaded')) {
        document.documentElement.classList.add('is-loading');
      }
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Açılış ekranı -->
    <div class="site-loader" aria-hidden="true">
      <div class="site-loader__inner">
        <img src="/logo.png" alt="Tozlu Skor" class="site-loader__logo" />
        <span class="site-loader__bar"></span>
      </div>
    </div>

    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      (function () {
        const loader = document.querySelector('.site-loader');
        if (!loader) return;
        function dismiss() {
          sessionStorage.setItem('ts_loaded', '1');
          loader.classList.add('site-loader--hide');
          document.documentElement.classList.remove('is-loading');
          setTimeout(() => loader.remove(), 700);
        }
        if (sessionStorage.getItem('ts_loaded')) {
          loader.remove();
          document.documentElement.classList.remove('is-loading');
        } else {
          window.addEventListener('load', () => setTimeout(dismiss, 600));
          // Güvenlik: 3sn sonra zorla kapat
          setTimeout(dismiss, 3000);
        }
      })();
    </script>
    <script is:inline>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", user => {
          if (!user) {
            window.netlifyIdentity.on("login", () => {
              document.location.href = "/admin/";
            });
          }
        });
      }
    </script>
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </body>
</html>
