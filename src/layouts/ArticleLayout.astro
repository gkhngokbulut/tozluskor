---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import CategoryBadge from '../components/ui/CategoryBadge.astro';
import Divider from '../components/ui/Divider.astro';

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  category: 'spor-kitapligi' | 'spor-filmografisi' | 'cumhuriyet-donemi-spor' | 'kisisel-blog';
  categoryLabel: string;
  meta?: string;
  tags?: string[];
  coverImage?: string;
}

const { title, description, publishDate, category, categoryLabel, meta, tags = [], coverImage } = Astro.props;

const formattedDate = publishDate.toLocaleDateString('tr-TR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

/* Tag slug helper */
function tagSlug(tag: string): string {
  return tag
    .toLowerCase()
    .replace(/ğ/g,'g').replace(/ü/g,'u').replace(/ş/g,'s')
    .replace(/ı/g,'i').replace(/ö/g,'o').replace(/ç/g,'c')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '');
}

/* Max 4 tags */
const visibleTags = tags.slice(0, 4);
---

<BaseLayout title={`${title} — Tozlu Skor`} description={description} ogType="article">
  <article class="max-w-2xl mx-auto px-6 py-12">

    <!-- Breadcrumb: son halka (yazı başlığı) kaldırıldı -->
    <div class="mb-8">
      <Breadcrumb
        items={[
          { label: categoryLabel, href: `/${category}` },
        ]}
      />
    </div>

    <!-- Makale başlığı -->
    <header class="mb-8">
      <CategoryBadge category={category} />

      <h1 class="font-heading text-3xl md:text-[2.6rem] font-bold text-vintage-dark mt-5 mb-5 leading-[1.15]">
        {title}
      </h1>

      <p class="font-body text-vintage-brown/70 text-lg italic leading-relaxed mb-6">{description}</p>

      <div class="flex flex-wrap items-center gap-3 text-xs text-vintage-muted/80 tracking-wide uppercase">
        <time datetime={publishDate.toISOString()}>
          {formattedDate}
        </time>
        {meta && (
          <>
            <span class="text-vintage-border">&middot;</span>
            <span class="normal-case tracking-normal italic text-sm">{meta}</span>
          </>
        )}
      </div>

      {visibleTags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-5">
          {visibleTags.map((tag) => (
            <a
              href={`/etiket/${tagSlug(tag)}/`}
              class="text-[11px] text-vintage-muted hover:text-vintage-red px-2.5 py-1 border border-vintage-border/60 hover:border-vintage-red/40 transition-colors"
            >
              #{tag}
            </a>
          ))}
        </div>
      )}
    </header>

    <!-- Ana öne çıkan görsel (başlığın altında) -->
    {coverImage && (
      <figure class="mb-10 -mx-6 md:mx-0 overflow-hidden md:border md:border-vintage-border/60">
        <img src={coverImage} alt={title} class="w-full h-56 md:h-80 object-cover" width="1200" height="630" loading="eager" />
      </figure>
    )}

    <Divider />

    <!-- Makale içeriği (iki yana yaslı) -->
    <div class="prose prose-lg max-w-none font-body article-body">
      <slot />
    </div>

    <Divider />

    <!-- Geri linki -->
    <div class="text-center">
      <a
        href={`/${category}`}
        class="inline-block text-[11px] text-vintage-brown/50 hover:text-vintage-red transition-colors uppercase tracking-[0.18em]"
      >
        &larr; {categoryLabel} sayfasına dön
      </a>
    </div>
  </article>
</BaseLayout>
