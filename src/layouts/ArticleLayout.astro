---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import CategoryBadge from '../components/ui/CategoryBadge.astro';
import Divider from '../components/ui/Divider.astro';

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  category: 'spor-kitapligi' | 'spor-filmografisi' | 'cumhuriyet-donemi-spor' | 'kisisel-blog';
  categoryLabel: string;
  meta?: string;
  tags?: string[];
}

const { title, description, publishDate, category, categoryLabel, meta, tags = [] } = Astro.props;

const formattedDate = publishDate.toLocaleDateString('tr-TR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} — Tozlu Skor`} description={description}>
  <article class="max-w-2xl mx-auto px-6 py-12">

    <div class="mb-8">
      <Breadcrumb
        items={[
          { label: categoryLabel, href: `/${category}` },
          { label: title },
        ]}
      />
    </div>

    <!-- Makale başlığı -->
    <header class="mb-10">
      <CategoryBadge category={category} />

      <h1 class="font-heading text-3xl md:text-[2.6rem] font-bold text-vintage-dark mt-5 mb-5 leading-[1.15]">
        {title}
      </h1>

      <p class="font-body text-vintage-brown/70 text-lg italic leading-relaxed mb-6">{description}</p>

      <div class="flex flex-wrap items-center gap-3 text-xs text-vintage-muted/80 tracking-wide uppercase">
        <time datetime={publishDate.toISOString()}>
          {formattedDate}
        </time>
        {meta && (
          <>
            <span class="text-vintage-border">&middot;</span>
            <span class="normal-case tracking-normal italic text-sm">{meta}</span>
          </>
        )}
      </div>

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-5">
          {tags.map((tag) => (
            <span class="text-[11px] text-vintage-muted px-2.5 py-1 border border-vintage-border/60">
              #{tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <Divider />

    <!-- Makale içeriği -->
    <div class="prose prose-lg max-w-none font-body">
      <slot />
    </div>

    <Divider />

    <!-- Geri linki -->
    <div class="text-center">
      <a
        href={`/${category}`}
        class="inline-block text-[11px] text-vintage-brown/50 hover:text-vintage-red transition-colors uppercase tracking-[0.18em]"
      >
        &larr; {categoryLabel} sayfasına dön
      </a>
    </div>
  </article>
</BaseLayout>
