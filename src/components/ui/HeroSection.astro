---
---

<section class="relative min-h-[80vh] flex items-center justify-center overflow-hidden">

  <!-- Zemin: düz koyu + tek hafif radial vurgu -->
  <div class="absolute inset-0 bg-vintage-dark"></div>
  <div class="absolute inset-0" style="background: radial-gradient(ellipse at 50% 60%, rgba(193,154,60,0.07) 0%, transparent 55%);"></div>
  <!-- Alt geçiş: içerik bölümüne yumuşak bağlantı -->
  <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-b from-transparent to-vintage-dark/60"></div>

  <!-- İçerik -->
  <div class="relative max-w-2xl mx-auto px-6 text-center text-vintage-cream">

    <!-- Üst etiket -->
    <p class="text-[10px] tracking-[0.45em] uppercase text-vintage-gold/60 mb-10">Est. 2026</p>

    <!-- Ana başlık -->
    <h2 class="font-heading text-5xl md:text-6xl lg:text-[4.5rem] font-bold leading-[1.08] mb-6 text-vintage-cream">
      Sporun<br />
      Toplumsal
      <span class="italic font-normal text-vintage-gold"> Hafızası</span>
    </h2>

    <!-- Ayırıcı -->
    <div class="flex justify-center items-center gap-3 mb-7">
      <div class="w-10 border-t border-vintage-gold/30"></div>
      <div class="w-1 h-1 bg-vintage-gold/50 rotate-45 shrink-0"></div>
      <div class="w-10 border-t border-vintage-gold/30"></div>
    </div>

    <!-- Alt açıklama -->
    <p class="text-vintage-cream/55 text-base md:text-lg leading-relaxed max-w-lg mx-auto mb-10 font-body">
      Kitaplar, filmler ve kişisel gözlemler aracılığıyla sporun tarihsel ve toplumsal boyutlarını keşfediyoruz.
    </p>

    <!-- Kategori linkleri -->
    <div class="flex flex-wrap justify-center gap-2 md:gap-3">
      <a href="/spor-kitapligi"
        class="text-[10px] uppercase tracking-[0.18em] text-vintage-cream/45 hover:text-vintage-gold border border-vintage-cream/12 hover:border-vintage-gold/35 px-4 py-2 transition-all duration-250">
        Kitaplık
      </a>
      <a href="/spor-filmografisi"
        class="text-[10px] uppercase tracking-[0.18em] text-vintage-cream/45 hover:text-vintage-gold border border-vintage-cream/12 hover:border-vintage-gold/35 px-4 py-2 transition-all duration-250">
        Filmografi
      </a>
      <a href="/cumhuriyet-donemi-spor"
        class="text-[10px] uppercase tracking-[0.18em] text-vintage-cream/45 hover:text-vintage-gold border border-vintage-cream/12 hover:border-vintage-gold/35 px-4 py-2 transition-all duration-250">
        Cumhuriyet Dönemi
      </a>
      <a href="/kisisel-blog"
        class="text-[10px] uppercase tracking-[0.18em] text-vintage-cream/45 hover:text-vintage-gold border border-vintage-cream/12 hover:border-vintage-gold/35 px-4 py-2 transition-all duration-250">
        Yazıyor Yazıyor
      </a>
    </div>

    <!-- Scroll göstergesi -->
    <div class="mt-14 flex flex-col items-center gap-2 text-vintage-cream/20">
      <span class="text-[9px] tracking-[0.35em] uppercase">Keşfet</span>
      <div class="w-px h-7 bg-gradient-to-b from-vintage-cream/20 to-transparent"></div>
    </div>

  </div>
</section>
