---
import CategoryBadge from './CategoryBadge.astro';

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  slug: string;
  category: 'spor-kitapligi' | 'spor-filmografisi' | 'cumhuriyet-donemi-spor' | 'kisisel-blog';
  meta?: string;
  coverImage?: string;
  excerpt?: string;
  minutes?: number;
}

const { title, description, publishDate, slug, category, meta, coverImage, excerpt, minutes } = Astro.props;

const formattedDate = publishDate.toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' });
const href = `/${category}/${slug}`;

const categoryLabels: Record<string, string> = {
  'spor-kitapligi': 'Spor Kitaplığı',
  'spor-filmografisi': 'Spor Filmografisi',
  'cumhuriyet-donemi-spor': 'Cumhuriyet Dönemi Spor',
  'kisisel-blog': 'Yazıyor Yazıyor',
};
const fallbackLabel: Record<string, string> = {
  'spor-kitapligi': 'KİTAP ARŞİVİ',
  'spor-filmografisi': 'FİLM ARŞİVİ',
  'cumhuriyet-donemi-spor': 'TARİHİ BELGE',
  'kisisel-blog': 'YAZI ARŞİVİ',
};
---

<article
  class={`card group cat-card cat-${category} bg-vintage-paper border overflow-hidden h-full flex flex-col`}
  data-preview
  data-pv-title={title}
  data-pv-cat={categoryLabels[category]}
  data-pv-href={href}
  data-pv-meta={meta || ''}
  data-pv-img={coverImage || ''}
  data-pv-min={minutes ? String(minutes) : ''}
  data-pv-excerpt={excerpt || description}
>
  <a href={href} class="card-media block" tabindex="-1" aria-hidden="true">
    {coverImage ? (
      <div class="media-inner"><img src={coverImage} alt="" loading="lazy" class="card-img" /></div>
    ) : (
      <div class={`media-inner visual-fallback fb-${category}`}>
        <span class="fb-label">{fallbackLabel[category]}</span>
        {category === 'spor-kitapligi' && (
          <div class="fb-books"><span class="sp s1"></span><span class="sp s2"></span><span class="sp s3"></span><span class="sp s4"></span><span class="sp s5"></span><span class="sp s6"></span></div>
        )}
        {category === 'spor-filmografisi' && (<div class="fb-film"><span class="reel"></span></div>)}
        {category === 'cumhuriyet-donemi-spor' && (
          <div class="fb-doc"><span class="doc-line"></span><span class="doc-line"></span><span class="doc-line short"></span></div>
        )}
        {category === 'kisisel-blog' && (
          <div class="fb-write"><span class="ink-line"></span><span class="ink-line"></span><span class="caret"></span></div>
        )}
      </div>
    )}
    <span class="media-fade"></span>
  </a>

  <div class="card-body relative flex flex-col flex-1 p-5">
    <div class="mb-3"><CategoryBadge category={category} /></div>

    <a href={href} class="block">
      <h3 class="font-heading text-lg md:text-xl font-bold text-vintage-dark group-hover:text-vintage-red transition-colors duration-200 leading-snug mb-2">{title}</h3>
    </a>

    {meta && <p class="text-xs text-vintage-muted/85 italic mb-2 tracking-wide">{meta}</p>}

    <p class="text-vintage-brown/80 text-sm leading-relaxed mb-4 line-clamp-2 pr-10">{description}</p>

    <div class="mt-auto flex items-center justify-between pt-3 border-t border-vintage-border/50">
      <time class="text-[11px] text-vintage-muted/70 tracking-wide" datetime={publishDate.toISOString()}>{formattedDate}</time>
      <span class="text-[11px] text-vintage-brown/55 group-hover:text-vintage-red transition-colors uppercase tracking-[0.15em]">Devamını Oku &rarr;</span>
    </div>

    <span class="cat-icon" aria-hidden="true">
      {category === 'spor-kitapligi' && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 5.5A1.5 1.5 0 015.5 4H10a2 2 0 012 2v13a2 2 0 00-2-1.6H5.5A1.5 1.5 0 014 16z"/>
          <path d="M20 5.5A1.5 1.5 0 0018.5 4H14a2 2 0 00-2 2v13a2 2 0 012-1.6h4.5A1.5 1.5 0 0020 16z"/>
        </svg>
      )}
      {category === 'spor-filmografisi' && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="16" rx="1.5"/>
          <path d="M7 4v16M17 4v16M3 9h4M3 14h4M17 9h4M17 14h4"/>
        </svg>
      )}
      {category === 'cumhuriyet-donemi-spor' && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
          <path d="M7 4h7l4 4v11a1 1 0 01-1 1H7a1 1 0 01-1-1V5a1 1 0 011-1z"/>
          <path d="M14 4v4h4"/>
          <path d="M9 13h6M9 16h4"/>
          <path d="M16.6 3.4a1.6 1.6 0 00-1.6 1.6v5.4a.85.85 0 001.7 0V5.4"/>
        </svg>
      )}
      {category === 'kisisel-blog' && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 19l2.5-.6L18 7.9a1.6 1.6 0 000-2.3l-.6-.6a1.6 1.6 0 00-2.3 0L4.6 15.5 4 18z"/>
          <path d="M13.5 6.5l3.9 3.9M5 21h14"/>
        </svg>
      )}
    </span>
  </div>
</article>

<style>
  .card {
    border-color: rgba(196, 184, 164, 0.6);
    cursor: pointer;
    transition: box-shadow 0.35s ease, border-color 0.35s ease;
  }
  .card:hover {
    box-shadow: 0 12px 36px rgba(34, 30, 26, 0.16);
    border-color: rgba(193, 154, 60, 0.4);
  }

  .card-media {
    position: relative; width: 100%; aspect-ratio: 16 / 10;
    overflow: hidden; background: var(--color-vintage-dark); flex-shrink: 0;
  }
  .media-inner { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; }
  .card-img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.6s cubic-bezier(0.22,1,0.36,1); }
  .card:hover .card-img { transform: scale(1.05); }
  .media-fade { position: absolute; inset: 0; pointer-events: none; box-shadow: inset 0 0 60px rgba(20,16,12,0.22); }

  .cat-icon {
    position: absolute; right: 0.9rem; bottom: 0.95rem;
    width: 30px; height: 30px; display: flex; align-items: center; justify-content: center;
    color: var(--color-vintage-gold); opacity: 0.5;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .cat-icon svg { width: 100%; height: 100%; }
  .card:hover .cat-icon { opacity: 0.95; transform: translateY(-1px); }

  .cat-card { border-top-width: 2px; }
  .cat-spor-kitapligi    { border-top-color: rgba(139,37,0,0.5); }
  .cat-spor-filmografisi { border-top-color: rgba(46,74,58,0.5); }
  .cat-cumhuriyet-donemi-spor { border-top-color: rgba(34,30,26,0.45); }
  .cat-kisisel-blog      { border-top-color: rgba(193,154,60,0.6); }

  .fb-label {
    position: absolute; bottom: 8px; left: 12px;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.5rem; letter-spacing: 0.22em; text-transform: uppercase;
    color: #C19A3C; opacity: 0.7; pointer-events: none; z-index: 2;
  }

  .visual-fallback { transition: filter 0.3s ease; }
  .card:hover .visual-fallback { filter: brightness(1.07); }

  .fb-spor-kitapligi { background: linear-gradient(158deg,#1a0f08,#231711 60%,#130b04); }
  .fb-books { display: flex; align-items: flex-end; gap: 4px; }
  .fb-books .sp { display:block; border-radius:1px 2px 0 0; }
  .s1{width:16px;height:60px;background:linear-gradient(#7a3820,#5c2a14);}
  .s2{width:12px;height:46px;background:linear-gradient(#2e5a4a,#1e3a30);}
  .s3{width:20px;height:72px;background:linear-gradient(#4a2060,#30124a);}
  .s4{width:14px;height:54px;background:linear-gradient(#8b3010,#6a2008);}
  .s5{width:18px;height:64px;background:linear-gradient(#c89410,#a07008);}
  .s6{width:10px;height:40px;background:linear-gradient(#3a3228,#262018);}

  .fb-spor-filmografisi { background:#0a0a0c; }
  .fb-spor-filmografisi::before { content:''; position:absolute; top:6px; left:6px; right:6px; height:6px; background:repeating-linear-gradient(90deg,rgba(255,255,255,.14) 0 8px,transparent 8px 15px); }
  .fb-spor-filmografisi::after  { content:''; position:absolute; bottom:6px; left:6px; right:6px; height:6px; background:repeating-linear-gradient(90deg,rgba(255,255,255,.14) 0 8px,transparent 8px 15px); }
  .fb-film .reel { width:46px; height:46px; border-radius:50%; border:2px solid rgba(193,154,60,.5); background:radial-gradient(circle,rgba(193,154,60,.14),rgba(0,0,0,.55)); }

  .fb-cumhuriyet-donemi-spor { background:linear-gradient(165deg,#ede2cb,#ddd0b2 55%,#cfc29e); }
  .fb-cumhuriyet-donemi-spor::after { content:''; position:absolute; inset:0; background-image:repeating-linear-gradient(0deg,transparent 0 18px,rgba(0,0,0,.04) 18px 19px); }
  .fb-doc { width:74px; height:92px; background:#f6efe0; border:1px solid rgba(34,30,26,.25); box-shadow:0 4px 10px rgba(0,0,0,.12); display:flex; flex-direction:column; justify-content:center; gap:7px; padding:0 12px; position:relative; }
  .fb-doc::before { content:''; position:absolute; top:-6px; right:14px; width:10px; height:26px; border:2px solid rgba(34,30,26,.5); border-radius:6px; }
  .doc-line { height:3px; background:rgba(34,30,26,.3); }
  .doc-line.short { width:60%; }

  .fb-kisisel-blog { background:linear-gradient(162deg,#231711,#160d07); }
  .fb-kisisel-blog::after { content:''; position:absolute; top:0; bottom:0; left:34px; width:1px; background:rgba(193,154,60,.18); }
  .fb-write { display:flex; flex-direction:column; gap:8px; align-items:flex-start; padding-left:18px; }
  .ink-line { width:90px; height:3px; background:rgba(239,232,218,.35); border-radius:2px; }
  .ink-line:nth-child(2){ width:64px; }
  .caret { width:2px; height:18px; background:#C19A3C; opacity:.7; animation:caretBlink 1.1s step-end infinite; }
  @keyframes caretBlink { 0%,100%{opacity:.7} 50%{opacity:0} }
</style>
