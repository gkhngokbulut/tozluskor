---
import CategoryBadge from './CategoryBadge.astro';

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  slug: string;
  category: 'spor-kitapligi' | 'spor-filmografisi' | 'cumhuriyet-donemi-spor' | 'kisisel-blog';
  meta?: string;
  coverImage?: string;
}

const { title, description, publishDate, slug, category, meta, coverImage } = Astro.props;

const formattedDate = publishDate.toLocaleDateString('tr-TR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const href = `/${category}/${slug}`;

const fallbackLabel: Record<string, string> = {
  'spor-kitapligi': 'KİTAP ARŞIVI',
  'spor-filmografisi': 'FİLM ARŞİVİ',
  'cumhuriyet-donemi-spor': 'SPOR ARŞİVİ',
  'kisisel-blog': 'YAZIYOR YAZIYOR',
};
---

<article class="group relative bg-vintage-paper border border-vintage-border rounded-sm overflow-hidden hover:shadow-lg transition-all duration-300 hover:-translate-y-0.5">

  <!-- Visual area: real cover image or category fallback -->
  <a href={href} class="visual-link block" tabindex="-1" aria-hidden="true">
    {coverImage ? (
      <div class="visual-area cover-image-area">
        <img src={coverImage} alt="" loading="lazy" />
      </div>
    ) : (
      <div class={`visual-area visual-fallback cat-${category}`}>
        <span class="vfb-label">{fallbackLabel[category]}</span>

        {category === 'spor-kitapligi' && (
          <div class="vfb-books">
            <div class="shelf-row">
              <span class="spine s1"></span>
              <span class="spine s2"></span>
              <span class="spine s3"></span>
              <span class="spine s4"></span>
              <span class="spine s5"></span>
              <span class="spine s6"></span>
            </div>
          </div>
        )}

        {category === 'spor-filmografisi' && (
          <div class="vfb-film">
            <div class="film-frame">
              <div class="film-lens"></div>
            </div>
          </div>
        )}

        {category === 'cumhuriyet-donemi-spor' && (
          <div class="vfb-newspaper">
            <span class="np-masthead">CUMHURİYET</span>
            <div class="np-rule"></div>
            <div class="np-cols">
              <div class="np-col"></div>
              <div class="np-col"></div>
              <div class="np-col"></div>
            </div>
          </div>
        )}

        {category === 'kisisel-blog' && (
          <div class="vfb-blog">
            <span class="blog-cursor"></span>
          </div>
        )}
      </div>
    )}
  </a>

  <!-- Card content -->
  <div class="card-body p-6 relative">
    <!-- Corner accents -->
    <div class="absolute top-0 left-0 w-4 h-4 border-t-2 border-l-2 border-vintage-red/30 rounded-tl-sm"></div>
    <div class="absolute top-0 right-0 w-4 h-4 border-t-2 border-r-2 border-vintage-red/30 rounded-tr-sm"></div>
    <div class="absolute bottom-0 left-0 w-4 h-4 border-b-2 border-l-2 border-vintage-red/30 rounded-bl-sm"></div>
    <div class="absolute bottom-0 right-0 w-4 h-4 border-b-2 border-r-2 border-vintage-red/30 rounded-br-sm"></div>

    <div class="mb-3">
      <CategoryBadge category={category} />
    </div>

    <a href={href} class="block">
      <h3 class="font-heading text-xl font-bold text-vintage-dark group-hover:text-vintage-red transition-colors mb-2">
        {title}
      </h3>
    </a>

    {meta && (
      <p class="text-sm text-vintage-muted italic mb-2 flex items-center gap-2">
        <span class="text-vintage-border">&mdash;</span>
        {meta}
      </p>
    )}

    <p class="text-vintage-brown/80 text-sm leading-relaxed mb-4 line-clamp-3">
      {description}
    </p>

    <div class="border-t border-vintage-border/50 pt-3 flex items-center justify-between">
      <time class="text-xs text-vintage-muted" datetime={publishDate.toISOString()}>
        {formattedDate}
      </time>
      <a href={href} class="text-xs text-vintage-red hover:text-vintage-dark transition-colors uppercase tracking-wider font-medium">
        Devamını Oku &rarr;
      </a>
    </div>
  </div>
</article>

<style>
  /* ── Visual area ── */
  .visual-area {
    width: 100%;
    height: 160px;
    position: relative;
    overflow: hidden;
    display: block;
    flex-shrink: 0;
  }

  /* Real cover image */
  .cover-image-area img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
    display: block;
  }

  .group:hover .cover-image-area img {
    transform: scale(1.05);
  }

  /* Fallback shared */
  .visual-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: filter 0.35s ease;
  }

  .group:hover .visual-fallback {
    filter: brightness(1.1) saturate(1.05);
  }

  /* Category label */
  .vfb-label {
    position: absolute;
    bottom: 8px;
    right: 10px;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 0.55rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #B8860B;
    opacity: 0.75;
    pointer-events: none;
    z-index: 2;
  }

  /* ══════════════════════════════════════
     spor-kitapligi — Book Shelf
  ══════════════════════════════════════ */
  .cat-spor-kitapligi {
    background: linear-gradient(158deg, #1a0f08 0%, #2c1810 55%, #150c05 100%);
  }

  /* warm glow from below */
  .cat-spor-kitapligi::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 110%, rgba(184,134,11,0.2) 0%, transparent 55%);
    pointer-events: none;
  }

  /* gold shelf plank */
  .cat-spor-kitapligi::after {
    content: '';
    position: absolute;
    bottom: 22px;
    left: 10%;
    right: 10%;
    height: 2px;
    background: linear-gradient(to right, transparent, rgba(184,134,11,0.55), transparent);
    pointer-events: none;
  }

  .vfb-books {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 24px;
  }

  .shelf-row {
    display: flex;
    align-items: flex-end;
    gap: 3px;
  }

  .spine {
    display: block;
    border-radius: 1px 2px 0 0;
    position: relative;
  }

  .spine::after {
    content: '';
    position: absolute;
    top: 6px;
    left: 0;
    right: 0;
    height: 1px;
    background: rgba(255,255,255,0.08);
  }

  .s1 { width: 16px; height: 68px; background: linear-gradient(to right, #7a3820, #5c2a14); }
  .s2 { width: 12px; height: 52px; background: linear-gradient(to right, #2e5a4a, #1e3a30); }
  .s3 { width: 20px; height: 80px; background: linear-gradient(to right, #4a2060, #30124a); }
  .s4 { width: 14px; height: 60px; background: linear-gradient(to right, #8b3010, #6a2008); }
  .s5 { width: 18px; height: 72px; background: linear-gradient(to right, #c89410, #a07008); }
  .s6 { width: 10px; height: 44px; background: linear-gradient(to right, #3a3228, #262018); }

  /* ══════════════════════════════════════
     spor-filmografisi — Film Strip / Cinema
  ══════════════════════════════════════ */
  .cat-spor-filmografisi {
    background: #080808;
  }

  /* projector beam glow */
  .cat-spor-filmografisi::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 80% at 50% 50%, rgba(255,210,80,0.1) 0%, transparent 70%);
    pointer-events: none;
  }

  /* top film perforations */
  .cat-spor-filmografisi::after {
    content: '';
    position: absolute;
    top: 5px;
    left: 5px;
    right: 5px;
    height: 8px;
    background: repeating-linear-gradient(
      90deg,
      rgba(255,255,255,0.16) 0px,
      rgba(255,255,255,0.16) 9px,
      transparent 9px,
      transparent 16px
    );
    pointer-events: none;
  }

  .vfb-film {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* bottom film perforations */
  .vfb-film::after {
    content: '';
    position: absolute;
    bottom: 5px;
    left: 5px;
    right: 5px;
    height: 8px;
    background: repeating-linear-gradient(
      90deg,
      rgba(255,255,255,0.16) 0px,
      rgba(255,255,255,0.16) 9px,
      transparent 9px,
      transparent 16px
    );
    pointer-events: none;
  }

  .film-frame {
    width: 88px;
    height: 68px;
    border: 2px solid rgba(184,134,11,0.55);
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(18,10,0,0.85);
    position: relative;
  }

  .film-lens {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 2px solid rgba(184,134,11,0.55);
    background: radial-gradient(circle, rgba(184,134,11,0.18) 0%, rgba(0,0,0,0.6) 100%);
    position: relative;
  }

  .film-lens::before {
    content: '';
    position: absolute;
    inset: 7px;
    border-radius: 50%;
    border: 1px solid rgba(184,134,11,0.3);
  }

  .film-lens::after {
    content: '';
    position: absolute;
    inset: 14px;
    border-radius: 50%;
    background: rgba(184,134,11,0.12);
  }

  /* ══════════════════════════════════════
     cumhuriyet-donemi-spor — Newspaper Archive
  ══════════════════════════════════════ */
  .cat-cumhuriyet-donemi-spor {
    background: linear-gradient(165deg, #f2e8d4 0%, #e4d8bc 50%, #d8cca8 100%);
  }

  /* ruled lines on paper */
  .cat-cumhuriyet-donemi-spor::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      0deg,
      transparent 0px,
      transparent 19px,
      rgba(0,0,0,0.05) 19px,
      rgba(0,0,0,0.05) 20px
    );
    pointer-events: none;
  }

  /* subtle sepia vignette */
  .cat-cumhuriyet-donemi-spor::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 50%, transparent 60%, rgba(44,24,16,0.12) 100%);
    pointer-events: none;
  }

  .vfb-newspaper {
    position: absolute;
    inset: 0;
    padding: 10px 14px 22px;
    display: flex;
    flex-direction: column;
    gap: 5px;
    z-index: 1;
  }

  .np-masthead {
    display: block;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: #2c1810;
    padding-bottom: 4px;
    border-bottom: 2px solid #2c1810;
  }

  .np-rule {
    height: 1px;
    background: rgba(44,24,16,0.25);
  }

  .np-cols {
    flex: 1;
    display: flex;
    gap: 8px;
    min-height: 0;
  }

  .np-col {
    flex: 1;
    background-image: repeating-linear-gradient(
      0deg,
      transparent 0px,
      transparent 7px,
      rgba(44,24,16,0.18) 7px,
      rgba(44,24,16,0.18) 8px
    );
    border-right: 1px solid rgba(44,24,16,0.12);
  }

  .np-col:last-child {
    border-right: none;
  }

  .cat-cumhuriyet-donemi-spor .vfb-label {
    color: #2c1810;
    opacity: 0.4;
  }

  /* ══════════════════════════════════════
     kisisel-blog — Writing Paper
  ══════════════════════════════════════ */
  .cat-kisisel-blog {
    background: linear-gradient(162deg, #2c1810 0%, #1a0f08 100%);
  }

  /* horizontal ruled lines */
  .cat-kisisel-blog::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      0deg,
      transparent 0px,
      transparent 19px,
      rgba(184,134,11,0.1) 19px,
      rgba(184,134,11,0.1) 20px
    );
    background-position: 0 8px;
    pointer-events: none;
  }

  /* left margin rule */
  .cat-kisisel-blog::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 34px;
    width: 1px;
    background: rgba(184,134,11,0.22);
    pointer-events: none;
  }

  .vfb-blog {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-left: 42px;
  }

  .blog-cursor {
    display: inline-block;
    width: 3px;
    height: 28px;
    background: #B8860B;
    opacity: 0.75;
    border-radius: 1px;
    animation: cursor-blink 1.1s step-end infinite;
  }

  @keyframes cursor-blink {
    0%, 100% { opacity: 0.75; }
    50% { opacity: 0; }
  }
</style>
