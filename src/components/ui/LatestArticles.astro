---
interface Props {
  title: string;
  href: string;
  subtitle?: string;
}
const { title, href, subtitle } = Astro.props;
---

<section class="py-12 md:py-14">
  <div class="flex items-end justify-between mb-2">
    <h2 class="font-heading text-2xl md:text-3xl font-bold text-vintage-dark tracking-tight">{title}</h2>
    <a href={href} class="text-[11px] uppercase tracking-[0.2em] text-vintage-muted/70 hover:text-vintage-red transition-colors duration-200 shrink-0 ml-4 pb-1">
      Tümünü Gör &rarr;
    </a>
  </div>
  {subtitle && (
    <p class="text-vintage-brown/65 text-sm md:text-[15px] font-body italic leading-relaxed max-w-xl mb-5">{subtitle}</p>
  )}
  <div class="flex items-center gap-3 mb-8">
    <div class="w-8 h-px bg-vintage-gold/50"></div>
    <div class="flex-1 h-px bg-vintage-border/50"></div>
  </div>
  <slot />
</section>
