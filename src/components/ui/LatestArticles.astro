---
interface Props {
  title: string;
  href: string;
  subtitle?: string;
}
const { title, href, subtitle } = Astro.props;
---

<section class="py-12 md:py-14">
  <div class="flex items-end justify-between mb-2">
    <h2 class="font-heading text-2xl md:text-3xl font-bold text-vintage-cream tracking-tight">{title}</h2>
    <a href={href} class="text-[11px] uppercase tracking-[0.2em] text-vintage-gold/55 hover:text-vintage-cream transition-colors duration-200 shrink-0 ml-4 pb-1">
      Tümünü Gör &rarr;
    </a>
  </div>
  {subtitle && (
    <p class="text-vintage-cream/50 text-sm md:text-[15px] font-body italic leading-relaxed max-w-xl mb-5">{subtitle}</p>
  )}
  <div class="flex items-center gap-3 mb-8">
    <div class="w-10 h-[2px] bg-gradient-to-r from-vintage-gold/60 to-vintage-gold/20 rounded-full"></div>
    <div class="w-1.5 h-1.5 bg-vintage-gold/35 rotate-45 shrink-0"></div>
    <div class="w-20 h-px bg-vintage-gold/10"></div>
  </div>
  <slot />
</section>
