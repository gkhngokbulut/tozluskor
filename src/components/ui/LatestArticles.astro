---
interface Props {
  title: string;
  href: string;
}

const { title, href } = Astro.props;
---

<section class="py-10">
  <div class="flex items-center justify-between mb-2">
    <h2 class="font-heading text-2xl font-bold text-vintage-dark">{title}</h2>
    <a href={href} class="text-sm text-vintage-red hover:text-vintage-dark transition-colors uppercase tracking-wider">
      Tümünü Gör &rarr;
    </a>
  </div>

  <!-- Decorative line under section title -->
  <div class="flex items-center gap-3 mb-8">
    <div class="w-16 h-0.5 bg-gradient-to-r from-vintage-red to-transparent"></div>
    <div class="w-1.5 h-1.5 bg-vintage-red/40 rotate-45"></div>
    <div class="flex-1 border-t border-vintage-border/40"></div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <slot />
  </div>
</section>
