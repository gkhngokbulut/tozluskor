---
interface Props {
  title: string;
  href: string;
}

const { title, href } = Astro.props;
---

<section class="py-12">
  <div class="flex items-baseline justify-between mb-6">
    <h2 class="font-heading text-2xl md:text-3xl font-bold text-vintage-dark tracking-tight">{title}</h2>
    <a href={href} class="text-[11px] uppercase tracking-[0.2em] text-vintage-muted/70 hover:text-vintage-red transition-colors duration-200 shrink-0 ml-4">
      Tümünü Gör &rarr;
    </a>
  </div>

  <!-- Bölüm ayırıcı -->
  <div class="flex items-center gap-3 mb-8">
    <div class="w-8 h-px bg-vintage-gold/50"></div>
    <div class="flex-1 h-px bg-vintage-border/50"></div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
    <slot />
  </div>
</section>
