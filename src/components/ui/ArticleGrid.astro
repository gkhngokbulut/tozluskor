---
import ArticleCard from './ArticleCard.astro';

interface Item {
  title: string;
  description: string;
  publishDate: Date;
  slug: string;
  category: 'spor-kitapligi' | 'spor-filmografisi' | 'cumhuriyet-donemi-spor' | 'kisisel-blog';
  meta?: string;
  coverImage?: string;
  excerpt?: string;
  minutes?: number;
}

interface Props { items: Item[]; }
const { items } = Astro.props;
---

{items.length === 0 ? (
  <p class="text-vintage-cream/40 text-center py-10 font-body italic">Bu bölümde henüz yazı yok.</p>
) : (
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-stretch">
    {items.map((it) => <ArticleCard {...it} />)}
  </div>
)}
