---
interface Props {
  category: 'spor-kitapligi' | 'spor-filmografisi' | 'cumhuriyet-donemi-spor' | 'kisisel-blog';
}

const { category } = Astro.props;

const config = {
  'spor-kitapligi': { label: 'Spor Kitaplığı', colorClass: 'text-vintage-red border-vintage-red/30' },
  'spor-filmografisi': { label: 'Spor Filmografisi', colorClass: 'text-vintage-green border-vintage-green/30' },
  'cumhuriyet-donemi-spor': { label: 'Cumhuriyet Dönemi Spor', colorClass: 'text-vintage-dark border-vintage-dark/25' },
  'kisisel-blog': { label: 'Yazıyor Yazıyor', colorClass: 'text-vintage-gold border-vintage-gold/35' },
};

const { label, colorClass } = config[category];
---

<span class:list={['inline-block text-[10px] uppercase tracking-[0.18em] px-2.5 py-1 border', colorClass]}>
  {label}
</span>
