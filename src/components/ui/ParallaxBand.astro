---
interface Props {
  quote?: string;
  author?: string;
}

const { quote, author } = Astro.props;
---

<div class="relative py-12 md:py-16 bg-vintage-dark text-vintage-cream overflow-hidden">
  <!-- Tek, sade radial vurgu -->
  <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at 50% 50%, rgba(193,154,60,0.06) 0%, transparent 60%);"></div>

  <div class="relative max-w-2xl mx-auto px-6 text-center">
    {quote ? (
      <>
        <div class="text-vintage-gold/25 text-4xl font-heading mb-3 leading-none">&ldquo;</div>
        <p class="text-vintage-cream/65 text-base md:text-lg italic font-body leading-relaxed mb-4">
          {quote}
        </p>
        {author && (
          <p class="text-vintage-gold/45 text-[11px] tracking-[0.25em] uppercase">— {author}</p>
        )}
      </>
    ) : (
      <div class="flex items-center justify-center gap-3">
        <div class="w-12 h-px bg-vintage-gold/20"></div>
        <div class="w-1 h-1 bg-vintage-gold/30 rotate-45 shrink-0"></div>
        <div class="w-12 h-px bg-vintage-gold/20"></div>
      </div>
    )}
  </div>
</div>
