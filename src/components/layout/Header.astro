---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Ana Sayfa' },
  { href: '/spor-kitapligi', label: 'Spor Kitaplığı' },
  { href: '/spor-filmografisi', label: 'Spor Filmografisi' },
  { href: '/cumhuriyet-donemi-spor', label: 'Cumhuriyet Dönemi Spor' },
  { href: '/kisisel-blog', label: 'Yazıyor Yazıyor' },
  { href: '/hakkimizda', label: 'Hakkımızda' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="bg-vintage-dark text-vintage-cream">
  <!-- Üst şerit -->
  <div class="border-b border-vintage-gold/20">
    <div class="max-w-6xl mx-auto px-6 py-1.5 text-center">
      <span class="text-[10px] tracking-[0.35em] uppercase text-vintage-muted/70">
        Spor &middot; Tarih &middot; Toplum &middot; Kültür
      </span>
    </div>
  </div>

  <!-- Logo -->
  <div class="max-w-6xl mx-auto px-6 py-5 text-center">
    <a href="/" class="inline-block">
      <img
        src="/logo.png"
        alt="Tozlu Skor"
        class="h-28 md:h-36 w-auto mx-auto"
      />
      <div class="flex justify-center items-center gap-4 mt-3 mb-2">
        <div class="w-16 border-t border-vintage-gold/25"></div>
        <div class="w-1 h-1 bg-vintage-gold/50 rotate-45 shrink-0"></div>
        <div class="w-16 border-t border-vintage-gold/25"></div>
      </div>
      <p class="text-[11px] text-vintage-muted/80 tracking-[0.28em] uppercase">Sporun Toplumsal Hafızası</p>
    </a>
  </div>

  <!-- Navigasyon -->
  <nav class="border-t border-vintage-gold/10 max-w-6xl mx-auto px-6">
    <!-- Desktop -->
    <ul class="hidden md:flex justify-center gap-1 py-0">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'relative inline-block px-3 py-3 text-[11px] uppercase tracking-[0.18em] transition-colors duration-200',
              isActive(link.href)
                ? 'text-vintage-gold after:absolute after:bottom-0 after:left-3 after:right-3 after:h-px after:bg-vintage-gold/60'
                : 'text-vintage-cream/65 hover:text-vintage-cream',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile toggle -->
    <div class="md:hidden flex justify-center py-3">
      <button
        id="mobile-menu-btn"
        class="text-vintage-cream/70 hover:text-vintage-gold transition-colors"
        aria-label="Menüyü aç"
        aria-expanded="false"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile menü -->
    <ul id="mobile-menu" class="md:hidden hidden flex-col items-center gap-1 pb-4">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'block px-4 py-2 text-[11px] uppercase tracking-[0.18em] transition-colors',
              isActive(link.href) ? 'text-vintage-gold' : 'text-vintage-cream/65 hover:text-vintage-cream',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden');
    menu?.classList.toggle('flex');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
