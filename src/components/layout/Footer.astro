---
const year = new Date().getFullYear();

const categories = [
  { href: '/spor-kitapligi', label: 'Spor Kitaplığı' },
  { href: '/spor-filmografisi', label: 'Spor Filmografisi' },
  { href: '/cumhuriyet-donemi-spor', label: 'Cumhuriyet Dönemi Spor' },
  { href: '/kisisel-blog', label: 'Yazıyor Yazıyor' },
];

const socials = [
  {
    label: 'X',
    href: 'https://x.com/TozluSkor',
    handle: '@TozluSkor',
    icon: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z',
  },
  {
    label: 'Instagram',
    href: 'https://www.instagram.com/tozluskor/',
    handle: '@tozluskor',
    icon: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z',
  },
  {
    label: 'YouTube',
    href: 'https://www.youtube.com/@TozluSkor',
    handle: '@TozluSkor',
    icon: 'M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z',
  },
];
---

<footer class="bg-vintage-dark text-vintage-cream/60">
  <div class="max-w-6xl mx-auto px-6 pt-14 pb-8">

    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 mb-12">
      <!-- Marka -->
      <div class="md:col-span-5">
        <img src="/logo.png" alt="Tozlu Skor" class="h-16 w-auto mb-4" />
        <p class="text-sm text-vintage-muted/70 leading-relaxed max-w-xs">
          Spor, tarih ve toplum üzerine okumalar, analizler ve düşünceler.
          Tozlu skorların peşinde.
        </p>
      </div>

      <!-- Kategoriler -->
      <div class="md:col-span-3">
        <p class="text-[10px] uppercase tracking-[0.25em] text-vintage-gold/50 mb-4">Bölümler</p>
        <ul class="space-y-2.5">
          {categories.map((cat) => (
            <li>
              <a href={cat.href} class="text-sm text-vintage-cream/45 hover:text-vintage-cream/85 transition-colors duration-200">
                {cat.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- İletişim -->
      <div class="md:col-span-4">
        <p class="text-[10px] uppercase tracking-[0.25em] text-vintage-gold/50 mb-4">İletişim</p>
        <ul class="space-y-2.5 mb-6">
          <li>
            <a href="/hakkimizda" class="text-sm text-vintage-cream/45 hover:text-vintage-cream/85 transition-colors duration-200">
              Hakkımızda
            </a>
          </li>
          <li>
            <a href="mailto:tozluskor@gmail.com" class="text-sm text-vintage-cream/45 hover:text-vintage-cream/85 transition-colors duration-200 inline-flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6">
                <rect x="3" y="5" width="18" height="14" rx="2" /><path d="M3 7l9 6 9-6" />
              </svg>
              tozluskor@gmail.com
            </a>
          </li>
        </ul>

        <!-- Sosyal medya -->
        <div class="flex items-center gap-3">
          {socials.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.label}
              title={`${s.label} — ${s.handle}`}
              class="inline-flex items-center justify-center w-9 h-9 border border-vintage-cream/15 text-vintage-cream/55 hover:text-vintage-dark hover:bg-vintage-gold hover:border-vintage-gold transition-all duration-300"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
                <path d={s.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="border-t border-vintage-gold/10 pt-5 text-center">
      <p class="text-[11px] text-vintage-muted/40 tracking-wide">
        &copy; {year} Tozlu Skor &middot; Tüm hakları saklıdır.
      </p>
    </div>

  </div>
</footer>
