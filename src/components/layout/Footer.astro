---
const year = new Date().getFullYear();

const categories = [
  { href: '/spor-kitapligi', label: 'Spor Kitaplığı' },
  { href: '/spor-filmografisi', label: 'Spor Filmografisi' },
  { href: '/cumhuriyet-donemi-spor', label: 'Cumhuriyet Dönemi Spor' },
  { href: '/kisisel-blog', label: 'Yazıyor Yazıyor' },
];
---

<footer class="bg-vintage-dark text-vintage-cream/60">
  <div class="max-w-6xl mx-auto px-6 pt-12 pb-8">

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-10">
      <!-- Marka -->
      <div>
        <p class="font-heading text-lg text-vintage-cream/90 mb-3 tracking-tight">TOZLU SKOR</p>
        <p class="text-sm text-vintage-muted/70 leading-relaxed max-w-xs">
          Spor, tarih ve toplum üzerine okumalar, analizler ve düşünceler.
        </p>
      </div>

      <!-- Kategoriler -->
      <div>
        <p class="text-[10px] uppercase tracking-[0.25em] text-vintage-gold/50 mb-4">Kategoriler</p>
        <ul class="space-y-2">
          {categories.map((cat) => (
            <li>
              <a href={cat.href} class="text-sm text-vintage-cream/45 hover:text-vintage-cream/80 transition-colors duration-200">
                {cat.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Hakkımızda -->
      <div>
        <p class="text-[10px] uppercase tracking-[0.25em] text-vintage-gold/50 mb-4">Künye</p>
        <a href="/hakkimizda" class="text-sm text-vintage-cream/45 hover:text-vintage-cream/80 transition-colors duration-200">
          Hakkımızda &rarr;
        </a>
      </div>
    </div>

    <!-- Alt çizgi -->
    <div class="border-t border-vintage-gold/10 pt-5 text-center">
      <p class="text-[11px] text-vintage-muted/40 tracking-wide">
        &copy; {year} Tozlu Skor
      </p>
    </div>

  </div>
</footer>
